// Prisma schema for PostgreSQL (Neon.tech)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model with roles array for RBAC
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  roles         String[]  @default([]) // admin, moderador, editor
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  videos        Video[]   @relation("UserVideos")

  @@index([email])
}

// NextAuth Account model
model Account {
  id                String   @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// NextAuth Session model (for database sessions if needed)
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// NextAuth VerificationToken model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Video status enum
enum VideoStatus {
  PENDING_UPLOAD
  UPLOADING
  QUEUED_FOR_TRANSCODE
  TRANSCODING
  READY
  FAILED
}

// Video model
model Video {
  id                  String       @id @default(uuid())
  title               String
  description         String       @default("")
  status              VideoStatus  @default(PENDING_UPLOAD)
  
  // R2 keys
  sourceKey           String?      // Original video in R2
  masterPlaylistKey   String?      // Master HLS playlist (.m3u8)
  thumbnailKey        String?      // Thumbnail image
  
  // Metadata
  duration            Int?         // Duration in seconds
  
  // Relations
  userId              String
  user                User         @relation("UserVideos", fields: [userId], references: [id], onDelete: Cascade)
  
  qualities           VideoQuality[] @relation("VideoQualities")
  subtitles           Subtitle[]     @relation("VideoSubtitles")
  
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Video quality/variant model for HLS
model VideoQuality {
  id          String   @id @default(uuid())
  videoId     String
  video       Video    @relation("VideoQualities", fields: [videoId], references: [id], onDelete: Cascade)
  
  label       String   // e.g., "1080p", "720p", "480p"
  width       Int
  height      Int
  bitrate     Int      // in kbps
  playlistKey String   // R2 key for variant .m3u8 playlist
  
  createdAt   DateTime @default(now())

  @@index([videoId])
}

// Subtitle model for SRT files
model Subtitle {
  id           String   @id @default(uuid())
  videoId      String
  video        Video    @relation("VideoSubtitles", fields: [videoId], references: [id], onDelete: Cascade)
  
  languageCode String   // e.g., "en", "pt", "es"
  label        String   // e.g., "English", "Português", "Español"
  key          String   // R2 key for SRT file
  
  createdAt    DateTime @default(now())

  @@index([videoId])
}
